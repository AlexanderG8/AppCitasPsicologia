@using AppCitasPsicologia.Models.Usuarios
@model Usuarios
@{
    ViewData["Title"] = "Crear Usuario";
    var empresaId = (int)ViewBag.EmpresaId;
    var nombreEmpresa = ViewBag.NombreEmpresa as string;
}

<!-- Breadcrumb -->
<nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
    <a asp-controller="Empresas" asp-action="Index" class="hover:text-indigo-600 transition-colors">Empresas</a>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
    </svg>
    <a asp-action="Index" asp-route-id="@empresaId" class="hover:text-indigo-600 transition-colors">Usuarios</a>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-slate-700 font-medium">Crear</span>
</nav>

<!-- Page header -->
<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-800">Crear Usuario</h1>
    <p class="text-sm text-slate-500 mt-0.5">@nombreEmpresa</p>
</div>

<!-- Card -->
<div class="bg-white rounded-xl border border-slate-200 shadow-sm max-w-2xl">
    <div class="px-6 py-5 border-b border-slate-100">
        <h2 class="text-base font-semibold text-slate-700">Datos del Usuario</h2>
        <p class="text-xs text-slate-400 mt-0.5">Se enviará un enlace al correo para que el usuario establezca su contraseña.</p>
    </div>

    <form asp-action="Crear" method="post" class="px-6 py-5 space-y-5">
        <input type="hidden" asp-for="EmpresaId" />

        <!-- Nombre y Apellido -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label asp-for="Nombres" class="block text-sm font-medium text-slate-700 mb-1.5">
                    Nombre <span class="text-red-500">*</span>
                </label>
                <input asp-for="Nombres" type="text"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="Nombres" class="text-xs text-red-500 mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Apellidos" class="block text-sm font-medium text-slate-700 mb-1.5">
                    Apellido <span class="text-red-500">*</span>
                </label>
                <input asp-for="Apellidos" type="text"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="Apellidos" class="text-xs text-red-500 mt-1 block"></span>
            </div>
        </div>

        <!-- Correo y Celular -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label asp-for="Email" class="block text-sm font-medium text-slate-700 mb-1.5">
                    Correo electrónico <span class="text-red-500">*</span>
                </label>
                <input asp-for="Email" type="email"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
            </div>
            <div>
                <label asp-for="NroCelular" class="block text-sm font-medium text-slate-700 mb-1.5">
                    Celular <span class="text-red-500">*</span>
                </label>
                <input asp-for="NroCelular" type="text"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="NroCelular" class="text-xs text-red-500 mt-1 block"></span>
            </div>
        </div>

        <!-- Fecha Nacimiento y Rol -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label asp-for="FechaNacimiento" class="block text-sm font-medium text-slate-700 mb-1.5">
                    Fecha de Nacimiento <span class="text-red-500">*</span>
                </label>
                <input asp-for="FechaNacimiento" type="date"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="FechaNacimiento" class="text-xs text-red-500 mt-1 block"></span>
            </div>
            <div>
                <label asp-for="RolId" class="block text-sm font-medium text-slate-700 mb-1.5">
                    Rol <span class="text-red-500">*</span>
                </label>
                <select asp-for="RolId" asp-items="ViewBag.Roles"
                        class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 bg-white text-slate-700
                               focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                </select>
                <span asp-validation-for="RolId" class="text-xs text-red-500 mt-1 block"></span>
            </div>
        </div>

        <!-- Tipo y Nro Documento -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label asp-for="TipoDocumento" class="block text-sm font-medium text-slate-700 mb-1.5">
                    Tipo Documento <span class="text-red-500">*</span>
                </label>
                <select asp-for="TipoDocumento"
                        class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 bg-white text-slate-700
                               focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    <option value="">-- Seleccione --</option>
                    <option value="DNI">DNI</option>
                    <option value="Pasaporte">Pasaporte</option>
                    <option value="Carnet de Extranjería">Carnet de Extranjería</option>
                </select>
                <span asp-validation-for="TipoDocumento" class="text-xs text-red-500 mt-1 block"></span>
            </div>
            <div>
                <label asp-for="NroDocumento" class="block text-sm font-medium text-slate-700 mb-1.5">
                    Nro. Documento <span class="text-red-500">*</span>
                </label>
                <input asp-for="NroDocumento" type="text"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="NroDocumento" class="text-xs text-red-500 mt-1 block"></span>
            </div>
        </div>

        <!-- Dirección -->
        <div>
            <label asp-for="Direccion" class="block text-sm font-medium text-slate-700 mb-1.5">
                Dirección <span class="text-red-500">*</span>
            </label>
            <textarea asp-for="Direccion" rows="2"
                      class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                             focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-none"></textarea>
            <span asp-validation-for="Direccion" class="text-xs text-red-500 mt-1 block"></span>
        </div>

        <!-- Buttons -->
        <div class="flex items-center gap-3 pt-2 border-t border-slate-100">
            <button type="submit"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                Crear y Enviar Correo
            </button>
            <a asp-action="Index" asp-route-id="@empresaId"
               class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 rounded-lg transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
