@{
    ViewData["Title"] = "Establecer Contraseña";
    var token = ViewBag.Token as string;
    var nombreUsuario = ViewBag.NombreUsuario as string;
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión — PsicoCitas</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head> 
<body class="min-h-screen bg-slate-50 flex items-center justify-center px-4">
    <div class="w-full max-w-md">

        <!-- Logo / ícono -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-indigo-600 shadow-lg mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-slate-800">Establece tu contraseña</h1>
            @if (!string.IsNullOrEmpty(nombreUsuario))
            {
                <p class="text-sm text-slate-500 mt-1">Hola <strong>@nombreUsuario</strong>, elige una contraseña segura.</p>
            }
        </div>

        <!-- Card -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8">
            <form asp-action="EstablecerContrasena" method="post" class="space-y-5">
                <input type="hidden" name="token" value="@token" />

                <!-- Contraseña -->
                <div>
                    <label for="contrasena" class="block text-sm font-medium text-slate-700 mb-1.5">
                        Contraseña <span class="text-red-500">*</span>
                    </label>
                    <input type="password" id="contrasena" name="contrasena" required minlength="6"
                           placeholder="Mínimo 6 caracteres"
                           class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                                  focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey("contrasena"))
                    {
                        <span class="text-xs text-red-500 mt-1 block">@ViewData.ModelState["contrasena"].Errors[0].ErrorMessage</span>
                    }
                </div>

                <!-- Confirmar Contraseña -->
                <div>
                    <label for="confirmarContrasena" class="block text-sm font-medium text-slate-700 mb-1.5">
                        Confirmar Contraseña <span class="text-red-500">*</span>
                    </label>
                    <input type="password" id="confirmarContrasena" name="confirmarContrasena" required
                           placeholder="Repite tu contraseña"
                           class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                                  focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey("confirmarContrasena"))
                    {
                        <span class="text-xs text-red-500 mt-1 block">@ViewData.ModelState["confirmarContrasena"].Errors[0].ErrorMessage</span>
                    }
                </div>

                <button type="submit"
                        class="w-full inline-flex items-center justify-center gap-2 px-5 py-3 bg-indigo-600 hover:bg-indigo-700
                               text-white text-sm font-semibold rounded-lg transition-colors shadow-sm mt-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    Guardar contraseña
                </button>
            </form>
        </div>
        <p class="text-center text-xs text-slate-400 mt-6">
            &copy; @DateTime.Now.Year PsicoCitas. Todos los derechos reservados.
        </p>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>