@using AppCitasPsicologia.Models.Roles
@model IEnumerable<Opciones>

@foreach (var opcion in Model)
{
    <li>
        <a asp-controller="@opcion.Controlador" asp-action="@opcion.Accion"
           class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400
                  hover:bg-slate-800 hover:text-white transition-colors duration-150">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 flex-shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="m16.49 12 3.75 3.75m0 0-3.75 3.75m3.75-3.75H3.74V4.499" />
            </svg>
            <span class="text-sm font-medium">@opcion.NombreOpcion</span>
        </a>
    </li>
}
