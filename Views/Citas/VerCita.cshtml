@using AppCitasPsicologia.Models.Citas
@model Citas
@{
    ViewData["Title"] = "Detalle de Cita";
}

<!-- Breadcrumb -->
<nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
    <a asp-action="Index" class="hover:text-indigo-600 transition-colors">Citas</a>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-slate-700 font-medium">Detalle</span>
</nav>

<!-- Page header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-slate-800">Detalle de Cita</h1>
        <p class="text-sm text-slate-500 mt-0.5">Cita #@Model.Id</p>
    </div>
</div>

<div class="max-w-3xl space-y-5">

    <!-- Participantes -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
            <h3 class="text-sm font-semibold text-slate-700">Participantes</h3>
        </div>
        <dl class="divide-y divide-slate-100">
            <div class="grid grid-cols-3 gap-4 px-6 py-3.5">
                <dt class="text-xs font-medium text-slate-500 uppercase tracking-wide self-center">Paciente</dt>
                <dd class="col-span-2 text-sm font-medium text-slate-700">@Model.NombreCliente</dd>
            </div>
            <div class="grid grid-cols-3 gap-4 px-6 py-3.5">
                <dt class="text-xs font-medium text-slate-500 uppercase tracking-wide self-center">Psicólogo</dt>
                <dd class="col-span-2 text-sm text-slate-700">@Model.NombrePsicologo</dd>
            </div>
        </dl>
    </div>

    <!-- Horario -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
            <h3 class="text-sm font-semibold text-slate-700">Horario</h3>
        </div>
        <dl class="divide-y divide-slate-100">
            <div class="grid grid-cols-3 gap-4 px-6 py-3.5">
                <dt class="text-xs font-medium text-slate-500 uppercase tracking-wide self-center">Fecha de reserva</dt>
                <dd class="col-span-2 text-sm text-slate-700">@Model.FechaReserva.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-PE"))</dd>
            </div>
            <div class="grid grid-cols-3 gap-4 px-6 py-3.5">
                <dt class="text-xs font-medium text-slate-500 uppercase tracking-wide self-center">Horario</dt>
                <dd class="col-span-2 text-sm text-slate-700">
                    @Model.HoraInicio.ToString(@"hh\:mm") – @Model.HoraFin.ToString(@"hh\:mm")
                </dd>
            </div>
            <div class="grid grid-cols-3 gap-4 px-6 py-3.5">
                <dt class="text-xs font-medium text-slate-500 uppercase tracking-wide self-center">Asistencia</dt>
                <dd class="col-span-2">
                    @if (string.IsNullOrEmpty(Model.Asistencia))
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-500">Pendiente</span>
                    }
                    else if (Model.Asistencia == "Asistió")
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-100">Asistió</span>
                    }
                    else
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-700 border border-red-100">No Asistió</span>
                    }
                </dd>
            </div>
        </dl>
    </div>

    <!-- Información adicional -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
            <h3 class="text-sm font-semibold text-slate-700">Información adicional</h3>
        </div>
        <dl class="divide-y divide-slate-100">
            <div class="grid grid-cols-3 gap-4 px-6 py-3.5">
                <dt class="text-xs font-medium text-slate-500 uppercase tracking-wide">Detalle</dt>
                <dd class="col-span-2 text-sm text-slate-700 leading-relaxed">@Model.DetalleCita</dd>
            </div>
            @if (!string.IsNullOrEmpty(Model.DocPago))
            {
                <div class="grid grid-cols-3 gap-4 px-6 py-3.5">
                    <dt class="text-xs font-medium text-slate-500 uppercase tracking-wide self-center">Doc. de pago</dt>
                    <dd class="col-span-2 text-sm text-slate-700">@Model.DocPago</dd>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.MotivoPostergacion))
            {
                <div class="grid grid-cols-3 gap-4 px-6 py-3.5">
                    <dt class="text-xs font-medium text-slate-500 uppercase tracking-wide">Motivo de postergación</dt>
                    <dd class="col-span-2 text-sm text-amber-700 bg-amber-50 rounded-lg px-3 py-2 leading-relaxed">@Model.MotivoPostergacion</dd>
                </div>
            }
            <div class="grid grid-cols-3 gap-4 px-6 py-3.5">
                <dt class="text-xs font-medium text-slate-500 uppercase tracking-wide self-center">Registrada el</dt>
                <dd class="col-span-2 text-sm text-slate-700">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</dd>
            </div>
            @if (Model.FechaActualizacion.HasValue)
            {
                <div class="grid grid-cols-3 gap-4 px-6 py-3.5">
                    <dt class="text-xs font-medium text-slate-500 uppercase tracking-wide self-center">Última actualización</dt>
                    <dd class="col-span-2 text-sm text-slate-700">@Model.FechaActualizacion.Value.ToString("dd/MM/yyyy HH:mm")</dd>
                </div>
            }
        </dl>
    </div>
    <!-- Actions -->
    <div class="flex items-center gap-3 pb-6">
        <a asp-action="Index"
           class="px-5 py-2.5 text-sm font-medium text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 rounded-lg transition-colors">
            Volver
        </a>
    </div>

</div>
