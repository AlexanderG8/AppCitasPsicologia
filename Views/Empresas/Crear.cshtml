@using AppCitasPsicologia.Models.Empresas
@model Empresas
@{
    ViewData["Title"] = "Crear Empresa";
}

<!-- Page header -->
<div class="mb-6">
    <div class="flex items-center gap-2 text-sm text-slate-500 mb-1">
        <a asp-action="Index" class="hover:text-indigo-600 transition-colors">Empresas</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-slate-700">Crear Empresa</span>
    </div>
    <h1 class="text-2xl font-bold text-slate-800">Crear Empresa</h1>
</div>

<!-- Form card -->
<div class="bg-white rounded-xl border border-slate-200 shadow-sm max-w-lg">
    <div class="px-6 py-5 border-b border-slate-100">
        <h2 class="text-base font-semibold text-slate-700">Información de la Empresa</h2>
        <p class="text-sm text-slate-400 mt-0.5">Complete los campos para registrar una nueva empresa.</p>
    </div>

    <form asp-action="Crear" method="post" class="px-6 py-5 space-y-5">
        <div>
            <label asp-for="Ruc" class="block text-sm font-medium text-slate-700 mb-1.5">RUC</label>
            <input asp-for="Ruc"
                   class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white text-slate-800
                          placeholder:text-slate-400
                          focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent
                          transition-colors"
                   placeholder="Ej: 20123456789" />
            <span asp-validation-for="Ruc" class="text-xs text-red-600 mt-1 block"></span>
        </div>

        <div>
            <label asp-for="NombreEmpresa" class="block text-sm font-medium text-slate-700 mb-1.5">Nombre de Empresa</label>
            <input asp-for="NombreEmpresa"
                   class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white text-slate-800
                          placeholder:text-slate-400
                          focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent
                          transition-colors"
                   placeholder="Ej: Clínica San Juan" />
            <span asp-validation-for="NombreEmpresa" class="text-xs text-red-600 mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Encargado" class="block text-sm font-medium text-slate-700 mb-1.5">Encargado</label>
            <input asp-for="Encargado"
                   class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white text-slate-800
                          placeholder:text-slate-400
                          focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent
                          transition-colors"
                   placeholder="Ej: Juan Pérez" />
            <span asp-validation-for="Encargado" class="text-xs text-red-600 mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Direccion" class="block text-sm font-medium text-slate-700 mb-1.5">Dirección</label>
            <textarea asp-for="Direccion" rows="3"
                      class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg bg-white text-slate-800
                             placeholder:text-slate-400
                             focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent
                             transition-colors resize-none"
                      placeholder="Ej: Av. Principal 123, Lima"></textarea>
            <span asp-validation-for="Direccion" class="text-xs text-red-600 mt-1 block"></span>
        </div>

        <div class="flex items-center gap-3 pt-2">
            <button type="submit"
                    class="inline-flex items-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700
                           text-white text-sm font-medium rounded-lg transition-colors shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                Guardar
            </button>
            <a asp-action="Index"
               class="inline-flex items-center gap-2 px-4 py-2.5 bg-white hover:bg-slate-50
                      text-slate-600 text-sm font-medium rounded-lg border border-slate-200
                      hover:border-slate-300 transition-colors">
                Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
