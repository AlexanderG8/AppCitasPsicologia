@using AppCitasPsicologia.Models.Usuarios
@model Usuarios
@{
    ViewData["Title"] = "Editar Paciente";
    var nombreEmpresa = ViewBag.NombreEmpresa as string;
}

<!-- Page header -->
<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-800">Editar Paciente</h1>
    <p class="text-sm text-slate-500 mt-0.5">@nombreEmpresa</p>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 max-w-2xl">
    <form asp-controller="Usuarios" asp-action="Editar" method="post" class="space-y-5">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="EmpresaId" />
        <input type="hidden" asp-for="RolId" />
        <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Pacientes")" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

            <!-- Nombres -->
            <div>
                <label asp-for="Nombres" class="block text-sm font-medium text-slate-700 mb-1.5">Nombres</label>
                <input asp-for="Nombres" type="text"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="Nombres" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Apellidos -->
            <div>
                <label asp-for="Apellidos" class="block text-sm font-medium text-slate-700 mb-1.5">Apellidos</label>
                <input asp-for="Apellidos" type="text"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="Apellidos" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Email -->
            <div>
                <label asp-for="Email" class="block text-sm font-medium text-slate-700 mb-1.5">Correo electrónico</label>
                <input asp-for="Email" type="email"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Celular -->
            <div>
                <label asp-for="NroCelular" class="block text-sm font-medium text-slate-700 mb-1.5">Nro. Celular</label>
                <input asp-for="NroCelular" type="text"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="NroCelular" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Fecha de Nacimiento -->
            <div>
                <label asp-for="FechaNacimiento" class="block text-sm font-medium text-slate-700 mb-1.5">Fecha de nacimiento</label>
                <input asp-for="FechaNacimiento" type="date"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="FechaNacimiento" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Tipo Documento -->
            <div>
                <label asp-for="TipoDocumento" class="block text-sm font-medium text-slate-700 mb-1.5">Tipo de documento</label>
                <select asp-for="TipoDocumento"
                        class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                               focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
                    <option value="">-- Seleccione --</option>
                    <option value="DNI">DNI</option>
                    <option value="Pasaporte">Pasaporte</option>
                    <option value="Carnet de Extranjería">Carnet de Extranjería</option>
                </select>
                <span asp-validation-for="TipoDocumento" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Nro Documento -->
            <div>
                <label asp-for="NroDocumento" class="block text-sm font-medium text-slate-700 mb-1.5">Nro. de documento</label>
                <input asp-for="NroDocumento" type="text"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="NroDocumento" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Dirección -->
            <div class="sm:col-span-2">
                <label asp-for="Direccion" class="block text-sm font-medium text-slate-700 mb-1.5">Dirección</label>
                <input asp-for="Direccion" type="text"
                       class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2.5 text-slate-700
                              focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                <span asp-validation-for="Direccion" class="text-xs text-red-500 mt-1 block"></span>
            </div>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-3 pt-2">
            <button type="submit"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                Guardar cambios
            </button>
            <a asp-action="Index"
               class="px-5 py-2.5 text-sm font-medium text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 rounded-lg transition-colors">
                Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
