@using AppCitasPsicologia.Models.Servicios
@model ServiciosPsicologosViewModel
@{
    ViewData["Title"] = "Servicios del Psicólogo";
    var totalServicios = Model.Servicios.Count();
    var totalSeleccionados = Model.Servicios.Count(s => s.Estado);
}

<!-- Breadcrumb -->
<nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
    <a asp-action="Index" class="hover:text-indigo-600 transition-colors">Psicólogos</a>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-slate-700 font-medium">Servicios</span>
</nav>

<!-- Page header -->
<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-800">Servicios del Psicólogo</h1>
    <p class="text-sm text-slate-500 mt-0.5">@Model.NombrePsicologo</p>
</div>

<form asp-action="GuardarServiciosPsicologo" method="post">
    <input type="hidden" name="psicologoId" value="@Model.IdPsicologo" />

    <!-- Card -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm max-w-2xl overflow-hidden">

        <!-- Card header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
            <div>
                <h2 class="text-sm font-semibold text-slate-700">Servicios disponibles</h2>
                <p class="text-xs text-slate-400 mt-0.5">
                    <span id="contadorSeleccionados">@totalSeleccionados</span> de @totalServicios seleccionado@(totalServicios == 1 ? "" : "s")
                </p>
            </div>
            <div class="flex items-center gap-2">
                <button type="button" id="btnSeleccionarTodo"
                        class="px-3 py-1.5 text-xs font-medium text-indigo-600 bg-indigo-50 hover:bg-indigo-100 border border-indigo-100 rounded-lg transition-colors">
                    Seleccionar todo
                </button>
                <button type="button" id="btnDeseleccionarTodo"
                        class="px-3 py-1.5 text-xs font-medium text-slate-600 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-lg transition-colors">
                    Deseleccionar todo
                </button>
            </div>
        </div>

        <!-- Lista de servicios -->
        @if (!Model.Servicios.Any())
        {
            <div class="px-6 py-10 text-center text-slate-400 text-sm">
                No hay servicios registrados para esta empresa.
            </div>
        }
        else
        {
            <ul class="divide-y divide-slate-100">
                @foreach (var servicio in Model.Servicios)
                {
                    <li class="flex items-center gap-4 px-6 py-3.5 hover:bg-slate-50 transition-colors">
                        <label class="flex items-center gap-3 flex-1 cursor-pointer select-none">
                            <input type="checkbox"
                                   name="serviciosSeleccionados"
                                   value="@servicio.Id"
                                   @(servicio.Estado ? "checked" : "")
                                   class="servicio-checkbox w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer" />
                            <div>
                                <span class="text-sm font-medium text-slate-700">@servicio.NombreServicio</span>
                                <span class="ml-2 text-xs text-slate-400">S/ @servicio.CostoServicio.ToString("N2")</span>
                            </div>
                        </label>
                        @if (servicio.Estado)
                        {
                            <span class="flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-100 estado-badge">
                                Activo
                            </span>
                        }
                        else
                        {
                            <span class="flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-400 border border-slate-200 estado-badge">
                                Inactivo
                            </span>
                        }
                    </li>
                }
            </ul>
        }

        <!-- Footer -->
        <div class="flex items-center gap-3 px-6 py-4 border-t border-slate-100 bg-slate-50">
            <button type="submit"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                Guardar Servicios
            </button>
            <a asp-action="Index"
               class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 rounded-lg transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Cancelar
            </a>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const checkboxes = document.querySelectorAll('.servicio-checkbox');
        const contador = document.getElementById('contadorSeleccionados');

        function actualizarContador() {
            contador.textContent = document.querySelectorAll('.servicio-checkbox:checked').length;
        }

        function actualizarBadge(checkbox) {
            const badge = checkbox.closest('li').querySelector('.estado-badge');
            if (checkbox.checked) {
                badge.textContent = 'Activo';
                badge.className = 'flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-100 estado-badge';
            } else {
                badge.textContent = 'Inactivo';
                badge.className = 'flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-400 border border-slate-200 estado-badge';
            }
        }

        checkboxes.forEach(cb => {
            cb.addEventListener('change', function () {
                actualizarBadge(this);
                actualizarContador();
            });
        });

        document.getElementById('btnSeleccionarTodo').addEventListener('click', function () {
            checkboxes.forEach(cb => { cb.checked = true; actualizarBadge(cb); });
            actualizarContador();
        });

        document.getElementById('btnDeseleccionarTodo').addEventListener('click', function () {
            checkboxes.forEach(cb => { cb.checked = false; actualizarBadge(cb); });
            actualizarContador();
        });
    </script>
}
